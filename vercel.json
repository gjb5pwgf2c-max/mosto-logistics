{
  "version": 2,
  "name": "mosto-logistics",
  "builds": [
    {
      "src": "index.html",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ],
  "env": {
    "VERCEL_ENV": "production",
    "SITE_NAME": "Mosto Logistics"
  }
}
